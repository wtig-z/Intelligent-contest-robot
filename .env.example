# ================================================================
# 智能竞赛客服机器人 — 环境变量配置
# 复制为 .env 后修改对应值
# ================================================================

# ── API Keys ───────────────────────────────────────────────────
DASHSCOPE_API_KEY=your_dashscope_api_key

# ── ViDoRAG 配置 ──────────────────────────────────────────────
VIDORAG_DATASET=CompetitionDataset
VIDORAG_EMBED_VL=vidore/colqwen2-v1.0
VIDORAG_EMBED_TEXT=BAAI/bge-m3
VIDORAG_LLM=qwen-vl-max

# ── 多轮→单轮总结 / 查询分类 LLM ─────────────────────────────
CHAT_LLM=qwen-turbo

# ── CUDA（可选，不填则使用默认）─────────────────────────────────
# CUDA_VISIBLE_DEVICES=0

# ── Server ─────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=0

# ── 阿里云 OSS（图片上传，不配置则图片走本地接口）──────────────
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_REGION=cn-guangzhou
OSS_BUCKET_NAME=aichord-test
OSS_PATH=ai/img/build
OSS_ENDPOINT=http://object.intuly.com
OSS_USE_CNAME=true

# ── 短信（可选，用于重置密码）──────────────────────────────────
# SMS_PROVIDER=aliyun
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=您的签名
# SMS_TEMPLATE_CODE_RESET_PASSWORD=您的模板CODE

# ── Auth / DB ──────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800
DATABASE_URL=sqlite:///data/contest_robot.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PHONE=13800000000

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_CAPACITY=300
LOG_STDOUT=1
